# Local lab rule for the generated DNS tunneling exercise traffic.
# Place in Suricata's local.rules or run with: suricata -r pcaps/demo_dns_tunnel.pcap -S rules/suricata_dns_tunnel.rules -k none

alert dns any any -> any any (msg:"LAB DNS tunneling domain tunnel.lab"; dns.query; content:".tunnel.lab"; nocase; sid:1000001; rev:1; classtype:policy-violation; metadata:exercise dns-tunneling;)

# Heuristic: catches many Base32-like labels of 45+ characters before the lab suffix.
# This is intentionally broad for teaching and should be tuned before production use.
alert dns any any -> any any (msg:"LAB Possible DNS tunnel long encoded label"; dns.query; pcre:"/[a-z2-7]{45,}\.[0-9]{3}\.[a-z0-9]{6}\.tunnel\.lab$/i"; sid:1000002; rev:1; classtype:policy-violation; metadata:exercise dns-tunneling;)
